# ---- Server ----
PORT=4000
NODE_ENV=development
# Comma-separated list of origins allowed to call this API from a BROWSER
# (irrelevant for the iOS app — CORS only applies to web requests).
# e.g. https://michiganbarandgrill.com,http://localhost:5500
ALLOWED_ORIGINS=http://localhost:5500

# ---- DeepSeek — powers the AI booking agent ----
# Get a key from https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
# deepseek-chat = general purpose (fast, supports tool calling — use this one)
# deepseek-reasoner = slower reasoning model, tool calling support may lag behind deepseek-chat
DEEPSEEK_MODEL=deepseek-chat

# ---- Google Calendar ----
# One shared service account authenticates for ALL businesses on the platform.
# 1. Create a Google Cloud project -> enable "Google Calendar API"
# 2. Create a Service Account -> generate a JSON key
# 3. For EACH business you onboard (see scripts/createBusiness.js), have them
#    share their calendar with this service account's email (the "client_email"
#    field in the JSON key) with "Make changes to events" permission.
# 4. Paste the FULL contents of the downloaded JSON key below as one line.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account", "...": "paste full key JSON here as one line"}

# Note: each business's own calendar ID, business hours, and menu/info are
# stored per-business in the database — see scripts/createBusiness.js to
# onboard a new business (this generates their API key too).

# ---- Email (optional — for the contact form) ----
# Leave blank to skip sending email; messages are still saved to the database.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_TO_EMAIL=info@michiganbarandgrill.com

# ---- Database ----
DB_PATH=./data/database.sqlite
